{
  "name": "johnnyxlemonade/vario-excel-exporter",
  "description": "Memory-efficient PHP utility for Excel dataset analysis and filtered streaming exports (XLSX, CSV, JSON). Built with OpenSpout and Clean Architecture.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-iconv": "*",
    "openspout/openspout": "^4.25"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^10.5 || ^11.0",
    "phpunit/php-code-coverage": "^10.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "stan": "phpstan analyse",
    "fix": "./vendor/bin/php-cs-fixer fix",
    "stan:ci": "phpstan analyse --no-progress --memory-limit=1G",
    "ci": [
      "@stan:ci"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  }
}
